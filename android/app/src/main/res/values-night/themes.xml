<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      深色模式下的 native 主题（仅启动瞬间可见）
      Compose 接管后会切到 Compose 的 darkColorScheme
    -->
    <style name="Theme.BieHuaLe" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.BieHuaLe.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenAnimationDuration">200</item>
        <item name="postSplashScreenTheme">@style/Theme.BieHuaLe</item>
    </style>
</resources>
